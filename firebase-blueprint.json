{
  "entities": {
    "User": {
      "title": "User",
      "description": "Company employee or admin",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "department": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Document": {
      "title": "Document",
      "description": "Indexed internal resource",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "sourceType": { "type": "string", "enum": ["wiki", "drive", "slack", "github"] },
        "department": { "type": "string" },
        "fileType": { "type": "string", "enum": ["pdf", "doc", "link", "message"] },
        "updatedAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "description", "url", "sourceType", "updatedAt"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "User saved document",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "documentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "documentId"]
    },
    "SearchHistory": {
      "title": "SearchHistory",
      "description": "User search queries",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Indexed internal documents"
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User bookmarks"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "SearchHistory",
      "description": "User search history"
    }
  }
}
